{
  "ops": [
    {
      "id": "agent",
      "args": {
        "image": "demi03/nosana-eliza-agent:latest",
        "expose": 3000,
        "env": {
          "OPENAI_API_KEY": "nosana",
          "OPENAI_API_URL": "https://inference.nosana.io/v1",
          "MODEL_NAME": "Qwen/Qwen2.5-72B-Instruct",
          "SERVER_PORT": "3000",
          "NODE_ENV": "production"
        }
      },
      "execution": {
        "group": "run"
      },
      "type": "container/run"
    }
  ],
  "version": "0.1"
}
